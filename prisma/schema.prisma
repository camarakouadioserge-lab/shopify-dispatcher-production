
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  CLOSER
}

enum DeliveryStatus {
  PENDING
  CALLED
  CONFIRMED
  SHIPPED
  IN_TRANSIT
  DELIVERED
  RETURNED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIALLY_PAID
  REFUNDED
  VOIDED
}

enum CallStatus {
  PENDING
  RINGING
  ANSWERED
  FAILED
  NO_ANSWER
  BUSY
  COMPLETED
}

enum CallResult {
  CONFIRMED
  CALLBACK
  WRONG_NUMBER
  ABSENT
  CANCELLED
  UNKNOWN
}

enum ExpenseCategory {
  ADS
  SALARY
  SHIPPING
  SOFTWARE
  REFUND
  OTHER
}

enum WebhookStatus {
  RECEIVED
  QUEUED
  PROCESSED
  DUPLICATE
  FAILED
}

enum AuditActorType {
  USER
  SYSTEM
  API
}

model Store {
  id              String           @id @default(cuid())
  name            String
  shopifyDomain   String           @unique
  accessToken     String?
  currency        String           @default("USD")
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  products        Product[]
  orders          Order[]
  expenses        Expense[]
  webhookReceipts WebhookReceipt[]
}

model User {
  id                  String                    @id @default(cuid())
  name                String
  email               String                    @unique
  phone               String?
  role                UserRole                  @default(CLOSER)
  active              Boolean                   @default(true)
  maxDailyOrders      Int                       @default(50)
  passwordHash        String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  assignments         CloserProductAssignment[]
  assignedOrders      Order[]                   @relation("AssignedOrders")
  calls               Call[]
  sessions            Session[]
  auditLogs           AuditLog[]                @relation("AuditActorUser")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  tokenHash    String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Product {
  id                String                    @id @default(cuid())
  storeId           String
  store             Store                     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  shopifyProductId  String
  shopifyVariantId  String?
  title             String
  sku               String?
  active            Boolean                   @default(true)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  assignments       CloserProductAssignment[]
  orderItems        OrderItem[]

  @@unique([storeId, shopifyProductId, shopifyVariantId])
  @@index([storeId, title])
}

model CloserProductAssignment {
  id          String   @id @default(cuid())
  closerId    String
  productId   String
  priority    Int      @default(100)
  countryCode String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  closer      User     @relation(fields: [closerId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([closerId, productId, countryCode])
  @@index([productId, countryCode, priority])
}

model Order {
  id                String           @id @default(cuid())
  storeId           String
  store             Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  shopifyOrderId    String
  orderNumber       String
  customerName      String
  phone             String?
  email             String?
  country           String?
  totalAmount       Decimal          @db.Decimal(12, 2)
  currency          String
  paymentStatus     PaymentStatus    @default(PENDING)
  fulfillmentStatus String?
  deliveryStatus    DeliveryStatus   @default(PENDING)
  assignedCloserId  String?
  assignedCloser    User?            @relation("AssignedOrders", fields: [assignedCloserId], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  orderItems        OrderItem[]
  calls             Call[]
  events            OrderEvent[]
  auditLogs         AuditLog[]
  webhookReceipts   WebhookReceipt[]

  @@unique([storeId, shopifyOrderId])
  @@index([assignedCloserId, createdAt])
  @@index([deliveryStatus, createdAt])
  @@index([country, createdAt])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String?
  title     String
  sku       String?
  quantity  Int
  unitPrice Decimal  @db.Decimal(12, 2)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
}

model Call {
  id             String      @id @default(cuid())
  orderId        String
  closerId       String?
  phoneNumber    String
  providerCallId String?
  callStatus     CallStatus  @default(PENDING)
  callResult     CallResult  @default(UNKNOWN)
  recordingUrl   String?
  startedAt      DateTime?
  endedAt        DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  order          Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  closer         User?       @relation(fields: [closerId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
  @@index([providerCallId])
}

model Expense {
  id          String          @id @default(cuid())
  storeId     String?
  country     String?
  category    ExpenseCategory
  label       String
  amount      Decimal         @db.Decimal(12, 2)
  expenseDate DateTime
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  store       Store?          @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([expenseDate, category])
}

model OrderEvent {
  id            String   @id @default(cuid())
  orderId       String?
  eventType     String
  source        String
  sourceEventId String?
  payloadJson   Json
  createdAt     DateTime @default(now())
  order         Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([source, sourceEventId])
  @@index([orderId, createdAt])
}

model WebhookReceipt {
  id             String        @id @default(cuid())
  source         String
  topic          String
  externalId     String
  shopDomain     String?
  status         WebhookStatus @default(RECEIVED)
  payloadJson    Json
  rawBody        String?
  orderId        String?
  storeId        String?
  errorMessage   String?
  receivedAt     DateTime      @default(now())
  queuedAt       DateTime?
  processedAt    DateTime?
  order          Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  store          Store?        @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@unique([source, externalId])
  @@index([status, receivedAt])
  @@index([shopDomain, topic, receivedAt])
}

model AuditLog {
  id            String         @id @default(cuid())
  actorType     AuditActorType
  actorUserId   String?
  action        String
  entityType    String
  entityId      String?
  orderId       String?
  metadataJson  Json
  createdAt     DateTime       @default(now())
  actorUser     User?          @relation("AuditActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  order         Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([orderId, createdAt])
}
